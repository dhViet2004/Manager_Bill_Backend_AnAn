{
  "name": "lam-anh-credit-backend",
  "version": "1.0.0",
  "description": "Backend API cho hệ thống quản lý thanh toán thẻ tín dụng",
  "scripts": {
    "dev": "dotenv -e .env -- next dev",
    "build": "prisma generate && next build",
    "start": "node startup.js",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "migrate:collected-amount": "tsx prisma/migrate-collected-amount.ts",
    "migrate:collected-amount:ci": "node -r tsx prisma/migrate-collected-amount.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.2.0",
    "next": "14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
